{
    "apiVersion": 3,
    "name": "gesimatic-static-forms/user-register",
    "title": "User Register",
    "category": "gesimatic",
    "icon": "forms",
    "description": "Register form for Wordpress users",
    "version": "1.0.0",
    "textdomain": "gesimatic-static-forms",
    "editorScript": "gesimatic-user-register-editor",
    "style": "file:./build/index.css",
    "viewScript":"gesimatic-user-register-js",

     "attributes": {
        "formId": {
            "type": "string",
            "default": "gesimatic-static-forms-0"
        },
        "showTitle": {
            "type": "boolean",
            "default": true
        },
        "title": {
            "type": "string",
            "default": "User register form"
        },
        "nameLabel": {
            "type": "string",
            "default": "User name"
        },
        "emailLabel": {
            "type": "string",
            "default": "User email"
        },
        "userRole": {
            "type": "string",
            "default": "subscriber"
        },
        "elementsColor": {
            "type": "string",
            "default": "#198754"
        },
        "buttonLabel": {
            "type": "string",
            "default": "Register"
        },
        "redirectUrl": {
            "type": "string",
            "default": ""
        }
    }
}
